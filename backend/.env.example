# Neon (pooling URL) - usada pelo app em runtime
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/xp_arcade?sslmode=require&pgbouncer=true&connect_timeout=15"
# Neon (direct URL) - usada pelo Prisma Migrate
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/xp_arcade?sslmode=require&connect_timeout=15"
PORT=8080
NODE_ENV=development

PAYMENT_PROVIDER=MOCK

# Segurança estação
STATION_TOKEN_SALT="change-me-local-salt"

# Chave para endpoints admin do backend
ADMIN_API_KEY="change-me-admin-key"

# Configuração Pix Sicoob (produção)
SICOOB_CLIENT_ID=""
SICOOB_CLIENT_SECRET=""
SICOOB_PIX_KEY=""
SICOOB_TOKEN_URL="https://apis.sisbr.com.br/cooperado/pix/token"
SICOOB_SCOPES="cob.write cob.read pix.read"
SICOOB_CERT_BASE64=""
SICOOB_KEY_BASE64=""
SICOOB_KEY_PASSPHRASE=""
SICOOB_WEBHOOK_SECRET=""
SICOOB_BASE_URL="https://api.sicoob.com.br/pix/api/v2"

BACKEND_PUBLIC_URL="http://localhost:8080"
